# =============================================================================
# Soothe Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values.
# These are environment variables required by LangChain tools and external APIs.
# For Soothe configuration, use config/config.yml instead of env vars.

# =============================================================================
# LLM Provider API Keys
# =============================================================================
# Required by LangChain and the OpenAI/Anthropic SDKs.
# Set at least one provider key for the agent to function.

OPENAI_API_KEY=sk-...                       # OpenAI or compatible provider
OPENAI_BASE_URL=                            # Override for OpenAI-compatible endpoints
ANTHROPIC_API_KEY=sk-ant-...                # Required for Claude subagent
OLLAMA_HOST=http://localhost:11434          # Ollama API endpoint

# =============================================================================
# Tool API Keys
# =============================================================================
# Required only if the corresponding tool or subagent is enabled in config.yml.

TAVILY_API_KEY=tvly-...                     # Tavily web search (research subagent, wizsearch engine)
SERPER_API_KEY=                             # Google Serper (optional backend for websearch tool)
JINA_API_KEY=jina_...                       # Jina Reader (optional backend for websearch crawl)
GITHUB_TOKEN=ghp_...                        # GitHub API (github tool)

# =============================================================================
# Infrastructure
# =============================================================================
# Used by vector store backends and docker-compose.yml.

POSTGRES_USER=postgres                      # PGVector database user
POSTGRES_PASSWORD=postgres                  # PGVector database password
POSTGRES_DB=vectordb                        # PGVector database name
WEAVIATE_URL=http://localhost:8080          # Weaviate HTTP endpoint

# =============================================================================
# Soothe Home
# =============================================================================

SOOTHE_HOME=~/.soothe                       # Soothe working directory

# =============================================================================
# Browser Subagent Privacy
# =============================================================================
# These are set automatically by the browser subagent.
# Override only if you need to re-enable these features.

# BROWSER_USE_DISABLE_EXTENSIONS=1          # Set to 0 to enable browser extensions
# BROWSER_USE_CLOUD_SYNC=false              # Set to true to enable cloud features
# ANONYMIZED_TELEMETRY=false                # Set to true to enable telemetry
