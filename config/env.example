# =============================================================================
# Soothe Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values.
# Variables marked [required] must be set for basic operation.
# Variables marked [optional] have sensible defaults.

# =============================================================================
# LLM Provider API Keys
# =============================================================================
# These are read by langchain, the OpenAI SDK, and Soothe's propagate_env().
# Set at least one provider key for the agent to function.

OPENAI_API_KEY=sk-...                       # [required] OpenAI or compatible provider
OPENAI_BASE_URL=                            # [optional] Override for OpenAI-compatible endpoints
ANTHROPIC_API_KEY=sk-ant-...                # [optional] Required for Claude subagent
OLLAMA_HOST=http://localhost:11434          # [optional] Ollama API endpoint (used by langchain-ollama)

# =============================================================================
# Tool API Keys
# =============================================================================
# Required only if the corresponding tool group or subagent is enabled in config.

TAVILY_API_KEY=tvly-...                     # [optional] Tavily web search (research subagent)
SERPER_API_KEY=                             # [optional] Google Serper web search
JINA_API_KEY=jina_...                       # [optional] Jina web reader / embeddings
GITHUB_TOKEN=ghp_...                        # [optional] GitHub API (github tool group)

# =============================================================================
# Soothe Home
# =============================================================================

SOOTHE_HOME=~/.soothe                       # [optional] Soothe working directory

# =============================================================================
# Soothe Configuration Overrides (SOOTHE_ prefix)
# =============================================================================
# These map directly to SootheConfig fields via pydantic-settings.
# A config YAML file (--config) takes precedence over env vars for
# complex fields; env vars are convenient for simple overrides.

SOOTHE_DEBUG=false                          # [optional] Enable debug logging
SOOTHE_SYSTEM_PROMPT=                       # [optional] Custom system prompt prepended to agent
SOOTHE_WORKSPACE_DIR=                       # [optional] Root directory for filesystem operations

# --- Protocol backends ---
SOOTHE_CONTEXT_BACKEND=keyword              # [optional] keyword | vector | none
SOOTHE_CONTEXT_PERSIST_DIR=                 # [optional] Directory for context persistence
SOOTHE_CONTEXT_PERSIST_BACKEND=json         # [optional] json | rocksdb
SOOTHE_MEMORY_BACKEND=none                  # [optional] store | vector | none
SOOTHE_MEMORY_PERSIST_PATH=                 # [optional] Path for memory persistence
SOOTHE_MEMORY_PERSIST_BACKEND=json          # [optional] json | rocksdb
SOOTHE_PLANNER_ROUTING=none                 # [optional] auto | always_direct | always_subagent | none
SOOTHE_POLICY_PROFILE=standard              # [optional] Policy profile name

# --- Embedding ---
SOOTHE_EMBEDDING_DIMS=1536                  # [optional] Must match embedding model output

# --- Vector store ---
SOOTHE_VECTOR_STORE_PROVIDER=none           # [optional] pgvector | weaviate | none
SOOTHE_VECTOR_STORE_COLLECTION=soothe_default

# =============================================================================
# Infrastructure (for vector store backends)
# =============================================================================
# Used by docker-compose.yml and vector store implementations.

POSTGRES_USER=postgres                      # PGVector database user
POSTGRES_PASSWORD=postgres                  # PGVector database password
POSTGRES_DB=vectordb                        # PGVector database name

WEAVIATE_URL=http://localhost:8080          # Weaviate HTTP endpoint

# =============================================================================
# Browser Subagent (privacy defaults)
# =============================================================================
# These are set automatically by the browser subagent factory.
# Override only if you need to re-enable these features.

# BROWSER_USE_DISABLE_EXTENSIONS=1          # Set to 0 to enable browser extensions
# BROWSER_USE_CLOUD_SYNC=false              # Set to true to enable cloud features
# ANONYMIZED_TELEMETRY=false                # Set to true to enable telemetry
